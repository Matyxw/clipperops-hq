# --- [ 1. SEGURIDAD CRÍTICA ] ---
# Nunca, bajo ninguna circunstancia, subas tus llaves del reino.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# --- [ 2. BASE DE DATOS Y PERSISTENCIA ] ---
# No subas tu base de datos local. El esquema se sube, el contenido NO.
# Si subís el .db, estás subiendo los nombres de tus clientes reales a la nube.
*.db
*.sqlite3
*.db-journal

# --- [ 3. EL "SÓTANO" DE NEXT.JS / NODE ] ---
node_modules/
.next/
out/
build/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- [ 4. EL "RUIDO" DE PYTHON ] ---
__pycache__/
*.py[cod]
*$py.class
.venv
venv/
ENV/
.pytest_cache/
.coverage
.ipynb_checkpoints/

# --- [ 5. BASURA DE SISTEMA OPERATIVO ] ---
# Para que cuando un pibe use Mac o Linux no vea tus archivos de Windows.
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/